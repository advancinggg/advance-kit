{
  "description": "Dev plugin — git auto-sync (pull on prompt, scan+generate+push on stop).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/git-auto-pull.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/stop.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
